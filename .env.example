# ============================================
# mailuse - Environment Configuration
# ============================================

# Domain
DOMAIN=yourdomain.com
APP_NAME=mailuse
EMAIL_TTL_SECONDS=3600

# ============================================
# API (apps/api)
# ============================================
DATABASE_URL=postgresql://mailuse:password@localhost:5432/mailuse
APP_DOMAIN=yourdomain.com
API_PORT=3000
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Storage (S3-compatible: MinIO, R2, etc.)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=emails
STORAGE_ACCESS_KEY=minio
STORAGE_SECRET_KEY=miniosecret
STORAGE_REGION=auto

# SMTP
SMTP_DOMAIN=yourdomain.com
SMTP_PORT=25

# Deploy mode: "docker" or "cloudflare"
DEPLOY_MODE=docker

# Auto-create inbox when email arrives for unknown address
AUTO_CREATE_INBOX=true

# ============================================
# Web (apps/web)
# ============================================
PUBLIC_API_BASE=http://localhost:3000
PUBLIC_API_URL=http://localhost:3000
PUBLIC_APP_DOMAIN=yourdomain.com
PUBLIC_EMAIL_DOMAIN=yourdomain.com
PUBLIC_APP_NAME=mailuse
