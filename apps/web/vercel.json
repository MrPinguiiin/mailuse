{
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "docs.mailuse.dev"
        }
      ],
      "destination": "/docs"
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "docs.mailuse.dev"
        }
      ],
      "destination": "/docs/:path*"
    }
  ]
}
