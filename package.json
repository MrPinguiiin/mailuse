{
  "name": "mailuse",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "hono": "^4.8.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:api": "turbo -F @mailuse/api dev",
    "dev:smtp": "turbo -F @mailuse/smtp dev",
    "db:push": "turbo -F @mailuse/db db:push",
    "db:studio": "turbo -F @mailuse/db db:studio",
    "db:generate": "turbo -F @mailuse/db db:generate",
    "db:migrate": "turbo -F @mailuse/db db:migrate"
  },
  "dependencies": {
    "@mailuse/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@mailuse/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.13"
}
