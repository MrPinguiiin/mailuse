model UpdateJob {
  id              String    @id
  triggeredBy     String    @map("triggered_by")
  triggeredByIp   String?   @map("triggered_by_ip")
  fromVersion     String    @map("from_version")
  toVersion       String    @map("to_version")
  releaseName     String?   @map("release_name")
  releaseUrl      String?   @map("release_url")
  status          String
  strategy        String
  phase           String?
  startedAt       DateTime  @default(now()) @map("started_at")
  completedAt     DateTime? @map("completed_at")
  durationSeconds Int?      @map("duration_seconds")
  logs            String?
  errorMessage    String?   @map("error_message")
  errorStack      String?   @map("error_stack")
  backupPath      String?   @map("backup_path")
  rollbackJobId   String?   @map("rollback_job_id")

  @@index([status, startedAt])
  @@map("update_jobs")
}

model UpdateLock {
  id        String   @id @default("singleton")
  lockedBy  String   @map("locked_by")
  lockedAt  DateTime @default(now()) @map("locked_at")
  expiresAt DateTime @map("expires_at")

  @@map("update_locks")
}
