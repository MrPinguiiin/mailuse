model Domain {
  id           String   @id
  domain       String   @unique
  providerType String   @map("provider_type") // "cloudflare" | "smtp"
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  inboxes Inbox[]

  @@map("domains")
}

model Inbox {
  id          String    @id
  address     String    @unique
  localPart   String    @map("local_part")
  domain      String
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  lastEmailAt DateTime? @map("last_email_at")
  isDeleted   Boolean   @default(false) @map("is_deleted")

  domainRef Domain? @relation(fields: [domain], references: [domain])
  emails    Email[]

  @@index([domain])
  @@index([expiresAt])
  @@index([isDeleted])
  @@map("inboxes")
}

model Email {
  id             String   @id
  inboxId        String   @map("inbox_id")
  messageId      String   @map("message_id")
  fromAddress    String   @map("from_address")
  toAddress      String   @map("to_address")
  subject        String   @default("")
  textBody       String?  @map("text_body")
  htmlBody       String?  @map("html_body")
  headers        Json?
  rawSize        Int      @default(0) @map("raw_size")
  receivedAt     DateTime @default(now()) @map("received_at")
  expiresAt      DateTime? @map("expires_at")
  hasAttachments Boolean  @default(false) @map("has_attachments")

  inbox       Inbox        @relation(fields: [inboxId], references: [id], onDelete: Cascade)
  attachments Attachment[]

  @@index([inboxId, receivedAt(sort: Desc)])
  @@index([messageId])
  @@map("emails")
}

model Attachment {
  id          String @id
  emailId     String @map("email_id")
  filename    String
  contentType String @map("content_type")
  size        Int
  storageKey  String @map("storage_key")

  email Email @relation(fields: [emailId], references: [id], onDelete: Cascade)

  @@index([emailId])
  @@map("attachments")
}

model BlockedLocalPart {
  id      String  @id
  pattern String  @unique
  reason  String?

  @@map("blocked_localparts")
}
